{
  "name": "Malayang Midnight Theme",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": {
      "foreground": "#cce0f2"
    },
    "label": {
      "foreground": "#f5afc1"
    },
    "class": {
      "foreground": "#bea9f5"
    },
    "class.defaultLibrary": {
      "foreground": "#bea9f5"
    },
    "interface": {
      "foreground": "#bea9f5"
    },
    "struct": {
      "foreground": "#bea9f5"
    },
    "enum": {
      "foreground": "#bea9f5"
    },
    "enumMember": {
      "foreground": "#f5afc1"
    },
    "type": {
      "foreground": "#bea9f5"
    },
    "type.defaultLibrary": {
      "foreground": "#bea9f5"
    },
    "typeParameter": {
      "foreground": "#72d1eb"
    },
    "parameter": {
      "foreground": "#dfc78f"
    },
    "variable": {
      "foreground": "#e4edf6"
    },
    "variable.defaultLibrary": {
      "foreground": "#e4edf6"
    },
    "variable.readonly": {
      "foreground": "#f5afc1"
    },
    "property": {
      "foreground": "#e4edf6"
    },
    "property.readonly": {
      "foreground": "#f5afc1"
    },
    "decorator": {
      "foreground": "#72d1eb"
    },
    "event": {
      "foreground": "#72d1eb"
    },
    "function": {
      "foreground": "#f2f7fc"
    },
    "function.defaultLibrary": {
      "foreground": "#f2f7fc"
    },
    "method": {
      "foreground": "#f2f7fc"
    },
    "method.defaultLibrary": {
      "foreground": "#f2f7fc"
    },
    "macro": {
      "foreground": "#72d1eb"
    },
    "keyword": {
      "foreground": "#72d1eb"
    },
    "comment": {
      "foreground": "#7a8898",
      "fontStyle": "italic"
    },
    "string": {
      "foreground": "#a7da85"
    },
    "regexp": {
      "foreground": "#84dfca"
    },
    "number": {
      "foreground": "#f5afc1"
    },
    "operator": {
      "foreground": "#72d1eb"
    }
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7a8898",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Invalid / deprecated",
      "scope": [
        "invalid",
        "invalid.illegal",
        "invalid.deprecated",
        "invalid.broken",
        "invalid.unimplemented"
      ],
      "settings": {
        "foreground": "#f1868e"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.return",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.exception",
        "keyword.other",
        "storage",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#72d1eb"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.expression",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.relational",
        "keyword.operator.increment",
        "keyword.operator.decrement"
      ],
      "settings": {
        "foreground": "#72d1eb"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#90a0b4"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "markup.inline.raw",
        "markup.fenced_code.block.markdown"
      ],
      "settings": {
        "foreground": "#a7da85"
      }
    },
    {
      "name": "String punctuation",
      "scope": [
        "punctuation.definition.string",
        "punctuation.quasi.element"
      ],
      "settings": {
        "foreground": "#a7da85"
      }
    },
    {
      "name": "String escapes",
      "scope": [
        "constant.character.escape",
        "constant.character.string.escape"
      ],
      "settings": {
        "foreground": "#72d1eb"
      }
    },
    {
      "name": "String interpolation punctuation",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.section.embedded.begin",
        "punctuation.section.embedded.end"
      ],
      "settings": {
        "foreground": "#72d1eb"
      }
    },
    {
      "name": "Template interpolation body",
      "scope": [
        "meta.template.expression",
        "source.ts.embedded",
        "source.js.embedded"
      ],
      "settings": {
        "foreground": "#e4edf6"
      }
    },
    {
      "name": "Regular expressions",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#84dfca"
      }
    },
    {
      "name": "RegExp punctuation/operators",
      "scope": [
        "keyword.operator.quantifier.regexp",
        "keyword.operator.or.regexp",
        "punctuation.definition.group.regexp",
        "punctuation.definition.character-class.regexp"
      ],
      "settings": {
        "foreground": "#72d1eb"
      }
    },
    {
      "name": "Numbers / constants",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language",
        "constant.character",
        "constant.other.symbol",
        "constant.other.color",
        "support.constant"
      ],
      "settings": {
        "foreground": "#f5afc1"
      }
    },
    {
      "name": "Enum members / readonly constants",
      "scope": [
        "variable.other.constant",
        "variable.other.enummember",
        "support.constant.property-value",
        "support.constant.color",
        "support.constant.color.w3c-standard-color-name"
      ],
      "settings": {
        "foreground": "#f5afc1"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "entity.name.interface",
        "entity.name.enum",
        "entity.name.type.alias",
        "support.type",
        "support.class",
        "storage.type",
        "storage.type.annotation",
        "storage.type.primitive",
        "storage.type.generic",
        "keyword.other.type"
      ],
      "settings": {
        "foreground": "#bea9f5"
      }
    },
    {
      "name": "Type parameters",
      "scope": [
        "entity.name.type.parameter",
        "variable.other.generic-type"
      ],
      "settings": {
        "foreground": "#72d1eb"
      }
    },
    {
      "name": "Namespaces / modules",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "entity.name.package",
        "entity.name.scope-resolution",
        "support.module",
        "support.type.module"
      ],
      "settings": {
        "foreground": "#cce0f2"
      }
    },
    {
      "name": "Functions / methods",
      "scope": [
        "entity.name.function",
        "entity.name.method",
        "support.function",
        "support.function.any-method",
        "variable.function",
        "meta.function-call",
        "meta.method-call",
        "meta.function.method",
        "meta.definition.method",
        "meta.function",
        "meta.method"
      ],
      "settings": {
        "foreground": "#f2f7fc"
      }
    },
    {
      "name": "Built-in functions",
      "scope": [
        "support.function.builtin",
        "support.function.console"
      ],
      "settings": {
        "foreground": "#eef5fb"
      }
    },
    {
      "name": "Decorators / annotations / macros",
      "scope": [
        "entity.name.decorator",
        "meta.function.decorator",
        "meta.annotation",
        "punctuation.definition.annotation",
        "support.type.property-name.annotation",
        "support.token.decorator.python"
      ],
      "settings": {
        "foreground": "#72d1eb"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "entity.name.variable",
        "support.variable",
        "meta.object-literal.key",
        "meta.definition.property"
      ],
      "settings": {
        "foreground": "#e4edf6"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.parameter",
        "function.parameter"
      ],
      "settings": {
        "foreground": "#dfc78f"
      }
    },
    {
      "name": "Properties / fields",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "entity.name.variable.field",
        "meta.property-name",
        "support.type.property-name",
        "support.type.property-name.json",
        "meta.mapping.key",
        "meta.mapping.key.yaml"
      ],
      "settings": {
        "foreground": "#e4edf6"
      }
    },
    {
      "name": "Language variables",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super",
        "support.variable.magic"
      ],
      "settings": {
        "foreground": "#72d1eb",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "entity.name.tag.custom",
        "entity.name.tag.localname",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#72d1eb"
      }
    },
    {
      "name": "Tag punctuation",
      "scope": [
        "punctuation.definition.tag",
        "meta.tag punctuation"
      ],
      "settings": {
        "foreground": "#90a0b4"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#f5afc1"
      }
    },
    {
      "name": "Selectors",
      "scope": [
        "meta.selector",
        "entity.other.attribute-name.class",
        "entity.other.attribute-name.id",
        "entity.other.attribute-name.pseudo-class",
        "entity.other.attribute-name.pseudo-element"
      ],
      "settings": {
        "foreground": "#72d1eb"
      }
    },
    {
      "name": "JSON / YAML keys",
      "scope": [
        "source.json meta.structure.dictionary > string.quoted.json",
        "source.json meta.structure.dictionary > string.quoted.json > punctuation.string",
        "support.type.property-name.json",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#e4edf6"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#bea9f5"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold",
        "punctuation.definition.bold"
      ],
      "settings": {
        "foreground": "#f5afc1"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic",
        "punctuation.definition.italic"
      ],
      "settings": {
        "foreground": "#72d1eb",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "markup.underline.link.image",
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#72d1eb"
      }
    },
    {
      "name": "Markdown quotes / list markers",
      "scope": [
        "markup.quote",
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#7a8898"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted",
        "markup.inserted.diff"
      ],
      "settings": {
        "foreground": "#a7da85"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted",
        "markup.deleted.diff"
      ],
      "settings": {
        "foreground": "#f1868e"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed",
        "markup.changed.diff"
      ],
      "settings": {
        "foreground": "#72d1eb"
      }
    }
  ],
