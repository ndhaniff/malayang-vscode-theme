{
  "name": "Malayang Light Theme",
  "type": "light",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": {
      "foreground": "#3d6996"
    },
    "label": {
      "foreground": "#c55372"
    },
    "class": {
      "foreground": "#7a5de0"
    },
    "class.defaultLibrary": {
      "foreground": "#7a5de0"
    },
    "interface": {
      "foreground": "#7a5de0"
    },
    "struct": {
      "foreground": "#7a5de0"
    },
    "enum": {
      "foreground": "#7a5de0"
    },
    "enumMember": {
      "foreground": "#c55372"
    },
    "type": {
      "foreground": "#7a5de0"
    },
    "type.defaultLibrary": {
      "foreground": "#7a5de0"
    },
    "typeParameter": {
      "foreground": "#0f80c2"
    },
    "parameter": {
      "foreground": "#9a752e"
    },
    "variable": {
      "foreground": "#243245"
    },
    "variable.defaultLibrary": {
      "foreground": "#243245"
    },
    "variable.readonly": {
      "foreground": "#c55372"
    },
    "property": {
      "foreground": "#243245"
    },
    "property.readonly": {
      "foreground": "#c55372"
    },
    "decorator": {
      "foreground": "#0f80c2"
    },
    "event": {
      "foreground": "#0f80c2"
    },
    "function": {
      "foreground": "#255e95"
    },
    "function.defaultLibrary": {
      "foreground": "#255e95"
    },
    "method": {
      "foreground": "#255e95"
    },
    "method.defaultLibrary": {
      "foreground": "#255e95"
    },
    "macro": {
      "foreground": "#0f80c2"
    },
    "keyword": {
      "foreground": "#0f80c2"
    },
    "comment": {
      "foreground": "#7a8796",
      "fontStyle": "italic"
    },
    "string": {
      "foreground": "#3f8656"
    },
    "regexp": {
      "foreground": "#0d847c"
    },
    "number": {
      "foreground": "#c55372"
    },
    "operator": {
      "foreground": "#0f80c2"
    }
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7a8796",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Invalid / deprecated",
      "scope": [
        "invalid",
        "invalid.illegal",
        "invalid.deprecated",
        "invalid.broken",
        "invalid.unimplemented"
      ],
      "settings": {
        "foreground": "#d95e67"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.return",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.exception",
        "keyword.other",
        "storage",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#0f80c2"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.expression",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.relational",
        "keyword.operator.increment",
        "keyword.operator.decrement"
      ],
      "settings": {
        "foreground": "#0f80c2"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#8090a3"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "markup.inline.raw",
        "markup.fenced_code.block.markdown"
      ],
      "settings": {
        "foreground": "#3f8656"
      }
    },
    {
      "name": "String punctuation",
      "scope": [
        "punctuation.definition.string",
        "punctuation.quasi.element"
      ],
      "settings": {
        "foreground": "#3f8656"
      }
    },
    {
      "name": "String escapes",
      "scope": [
        "constant.character.escape",
        "constant.character.string.escape"
      ],
      "settings": {
        "foreground": "#0f80c2"
      }
    },
    {
      "name": "String interpolation punctuation",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.section.embedded.begin",
        "punctuation.section.embedded.end"
      ],
      "settings": {
        "foreground": "#0f80c2"
      }
    },
    {
      "name": "Template interpolation body",
      "scope": [
        "meta.template.expression",
        "source.ts.embedded",
        "source.js.embedded"
      ],
      "settings": {
        "foreground": "#243245"
      }
    },
    {
      "name": "Regular expressions",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#0d847c"
      }
    },
    {
      "name": "RegExp punctuation/operators",
      "scope": [
        "keyword.operator.quantifier.regexp",
        "keyword.operator.or.regexp",
        "punctuation.definition.group.regexp",
        "punctuation.definition.character-class.regexp"
      ],
      "settings": {
        "foreground": "#0f80c2"
      }
    },
    {
      "name": "Numbers / constants",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language",
        "constant.character",
        "constant.other.symbol",
        "constant.other.color",
        "support.constant"
      ],
      "settings": {
        "foreground": "#c55372"
      }
    },
    {
      "name": "Enum members / readonly constants",
      "scope": [
        "variable.other.constant",
        "variable.other.enummember",
        "support.constant.property-value",
        "support.constant.color",
        "support.constant.color.w3c-standard-color-name"
      ],
      "settings": {
        "foreground": "#c55372"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "entity.name.interface",
        "entity.name.enum",
        "entity.name.type.alias",
        "support.type",
        "support.class",
        "storage.type",
        "storage.type.annotation",
        "storage.type.primitive",
        "storage.type.generic",
        "keyword.other.type"
      ],
      "settings": {
        "foreground": "#7a5de0"
      }
    },
    {
      "name": "Type parameters",
      "scope": [
        "entity.name.type.parameter",
        "variable.other.generic-type"
      ],
      "settings": {
        "foreground": "#0f80c2"
      }
    },
    {
      "name": "Namespaces / modules",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "entity.name.package",
        "entity.name.scope-resolution",
        "support.module",
        "support.type.module"
      ],
      "settings": {
        "foreground": "#3d6996"
      }
    },
    {
      "name": "Functions / methods",
      "scope": [
        "entity.name.function",
        "entity.name.method",
        "support.function",
        "support.function.any-method",
        "variable.function",
        "meta.function-call",
        "meta.method-call",
        "meta.function.method",
        "meta.definition.method",
        "meta.function",
        "meta.method"
      ],
      "settings": {
        "foreground": "#255e95"
      }
    },
    {
      "name": "Built-in functions",
      "scope": [
        "support.function.builtin",
        "support.function.console"
      ],
      "settings": {
        "foreground": "#0068a1"
      }
    },
    {
      "name": "Decorators / annotations / macros",
      "scope": [
        "entity.name.decorator",
        "meta.function.decorator",
        "meta.annotation",
        "punctuation.definition.annotation",
        "support.type.property-name.annotation",
        "support.token.decorator.python"
      ],
      "settings": {
        "foreground": "#0f80c2"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "entity.name.variable",
        "support.variable",
        "meta.object-literal.key",
        "meta.definition.property"
      ],
      "settings": {
        "foreground": "#243245"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.parameter",
        "function.parameter"
      ],
      "settings": {
        "foreground": "#9a752e"
      }
    },
    {
      "name": "Properties / fields",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "entity.name.variable.field",
        "meta.property-name",
        "support.type.property-name",
        "support.type.property-name.json",
        "meta.mapping.key",
        "meta.mapping.key.yaml"
      ],
      "settings": {
        "foreground": "#243245"
      }
    },
    {
      "name": "Language variables",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super",
        "support.variable.magic"
      ],
      "settings": {
        "foreground": "#0f80c2",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "entity.name.tag.custom",
        "entity.name.tag.localname",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#0f80c2"
      }
    },
    {
      "name": "Tag punctuation",
      "scope": [
        "punctuation.definition.tag",
        "meta.tag punctuation"
      ],
      "settings": {
        "foreground": "#8090a3"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#c55372"
      }
    },
    {
      "name": "Selectors",
      "scope": [
        "meta.selector",
        "entity.other.attribute-name.class",
        "entity.other.attribute-name.id",
        "entity.other.attribute-name.pseudo-class",
        "entity.other.attribute-name.pseudo-element"
      ],
      "settings": {
        "foreground": "#0f80c2"
      }
    },
    {
      "name": "JSON / YAML keys",
      "scope": [
        "source.json meta.structure.dictionary > string.quoted.json",
        "source.json meta.structure.dictionary > string.quoted.json > punctuation.string",
        "support.type.property-name.json",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#243245"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#7a5de0"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold",
        "punctuation.definition.bold"
      ],
      "settings": {
        "foreground": "#c55372"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic",
        "punctuation.definition.italic"
      ],
      "settings": {
        "foreground": "#0f80c2",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "markup.underline.link.image",
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#0f80c2"
      }
    },
    {
      "name": "Markdown quotes / list markers",
      "scope": [
        "markup.quote",
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#7a8796"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted",
        "markup.inserted.diff"
      ],
      "settings": {
        "foreground": "#3f8656"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted",
        "markup.deleted.diff"
      ],
      "settings": {
        "foreground": "#d95e67"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed",
        "markup.changed.diff"
      ],
      "settings": {
        "foreground": "#0f80c2"
      }
    }
  ],
