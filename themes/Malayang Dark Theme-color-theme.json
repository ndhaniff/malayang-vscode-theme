{
  "name": "Malayang Dark Theme",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": {
      "foreground": "#c2d7ea"
    },
    "label": {
      "foreground": "#f2a7bb"
    },
    "class": {
      "foreground": "#b49cf0"
    },
    "class.defaultLibrary": {
      "foreground": "#b49cf0"
    },
    "interface": {
      "foreground": "#b49cf0"
    },
    "struct": {
      "foreground": "#b49cf0"
    },
    "enum": {
      "foreground": "#b49cf0"
    },
    "enumMember": {
      "foreground": "#f2a7bb"
    },
    "type": {
      "foreground": "#b49cf0"
    },
    "type.defaultLibrary": {
      "foreground": "#b49cf0"
    },
    "typeParameter": {
      "foreground": "#67cbe7"
    },
    "parameter": {
      "foreground": "#d8bf88"
    },
    "variable": {
      "foreground": "#dce6f2"
    },
    "variable.defaultLibrary": {
      "foreground": "#dce6f2"
    },
    "variable.readonly": {
      "foreground": "#f2a7bb"
    },
    "property": {
      "foreground": "#dce6f2"
    },
    "property.readonly": {
      "foreground": "#f2a7bb"
    },
    "decorator": {
      "foreground": "#67cbe7"
    },
    "event": {
      "foreground": "#67cbe7"
    },
    "function": {
      "foreground": "#eef4fb"
    },
    "function.defaultLibrary": {
      "foreground": "#eef4fb"
    },
    "method": {
      "foreground": "#eef4fb"
    },
    "method.defaultLibrary": {
      "foreground": "#eef4fb"
    },
    "macro": {
      "foreground": "#67cbe7"
    },
    "keyword": {
      "foreground": "#67cbe7"
    },
    "comment": {
      "foreground": "#748396",
      "fontStyle": "italic"
    },
    "string": {
      "foreground": "#9fd47e"
    },
    "regexp": {
      "foreground": "#79d7c3"
    },
    "number": {
      "foreground": "#f2a7bb"
    },
    "operator": {
      "foreground": "#67cbe7"
    }
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#748396",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Invalid / deprecated",
      "scope": [
        "invalid",
        "invalid.illegal",
        "invalid.deprecated",
        "invalid.broken",
        "invalid.unimplemented"
      ],
      "settings": {
        "foreground": "#ef7d86"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.return",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.exception",
        "keyword.other",
        "storage",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#67cbe7"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.expression",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.relational",
        "keyword.operator.increment",
        "keyword.operator.decrement"
      ],
      "settings": {
        "foreground": "#67cbe7"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#8a97a8"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "markup.inline.raw",
        "markup.fenced_code.block.markdown"
      ],
      "settings": {
        "foreground": "#9fd47e"
      }
    },
    {
      "name": "String punctuation",
      "scope": [
        "punctuation.definition.string",
        "punctuation.quasi.element"
      ],
      "settings": {
        "foreground": "#9fd47e"
      }
    },
    {
      "name": "String escapes",
      "scope": [
        "constant.character.escape",
        "constant.character.string.escape"
      ],
      "settings": {
        "foreground": "#67cbe7"
      }
    },
    {
      "name": "String interpolation punctuation",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.section.embedded.begin",
        "punctuation.section.embedded.end"
      ],
      "settings": {
        "foreground": "#67cbe7"
      }
    },
    {
      "name": "Template interpolation body",
      "scope": [
        "meta.template.expression",
        "source.ts.embedded",
        "source.js.embedded"
      ],
      "settings": {
        "foreground": "#dce6f2"
      }
    },
    {
      "name": "Regular expressions",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#79d7c3"
      }
    },
    {
      "name": "RegExp punctuation/operators",
      "scope": [
        "keyword.operator.quantifier.regexp",
        "keyword.operator.or.regexp",
        "punctuation.definition.group.regexp",
        "punctuation.definition.character-class.regexp"
      ],
      "settings": {
        "foreground": "#67cbe7"
      }
    },
    {
      "name": "Numbers / constants",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language",
        "constant.character",
        "constant.other.symbol",
        "constant.other.color",
        "support.constant"
      ],
      "settings": {
        "foreground": "#f2a7bb"
      }
    },
    {
      "name": "Enum members / readonly constants",
      "scope": [
        "variable.other.constant",
        "variable.other.enummember",
        "support.constant.property-value",
        "support.constant.color",
        "support.constant.color.w3c-standard-color-name"
      ],
      "settings": {
        "foreground": "#f2a7bb"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "entity.name.interface",
        "entity.name.enum",
        "entity.name.type.alias",
        "support.type",
        "support.class",
        "storage.type",
        "storage.type.annotation",
        "storage.type.primitive",
        "storage.type.generic",
        "keyword.other.type"
      ],
      "settings": {
        "foreground": "#b49cf0"
      }
    },
    {
      "name": "Type parameters",
      "scope": [
        "entity.name.type.parameter",
        "variable.other.generic-type"
      ],
      "settings": {
        "foreground": "#67cbe7"
      }
    },
    {
      "name": "Namespaces / modules",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "entity.name.package",
        "entity.name.scope-resolution",
        "support.module",
        "support.type.module"
      ],
      "settings": {
        "foreground": "#c2d7ea"
      }
    },
    {
      "name": "Functions / methods",
      "scope": [
        "entity.name.function",
        "entity.name.method",
        "support.function",
        "support.function.any-method",
        "variable.function",
        "meta.function-call",
        "meta.method-call",
        "meta.function.method",
        "meta.definition.method",
        "meta.function",
        "meta.method"
      ],
      "settings": {
        "foreground": "#eef4fb"
      }
    },
    {
      "name": "Built-in functions",
      "scope": [
        "support.function.builtin",
        "support.function.console"
      ],
      "settings": {
        "foreground": "#e5eff9"
      }
    },
    {
      "name": "Decorators / annotations / macros",
      "scope": [
        "entity.name.decorator",
        "meta.function.decorator",
        "meta.annotation",
        "punctuation.definition.annotation",
        "support.type.property-name.annotation",
        "support.token.decorator.python"
      ],
      "settings": {
        "foreground": "#67cbe7"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "entity.name.variable",
        "support.variable",
        "meta.object-literal.key",
        "meta.definition.property"
      ],
      "settings": {
        "foreground": "#dce6f2"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.parameter",
        "function.parameter"
      ],
      "settings": {
        "foreground": "#d8bf88"
      }
    },
    {
      "name": "Properties / fields",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "entity.name.variable.field",
        "meta.property-name",
        "support.type.property-name",
        "support.type.property-name.json",
        "meta.mapping.key",
        "meta.mapping.key.yaml"
      ],
      "settings": {
        "foreground": "#dce6f2"
      }
    },
    {
      "name": "Language variables",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super",
        "support.variable.magic"
      ],
      "settings": {
        "foreground": "#67cbe7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "entity.name.tag.custom",
        "entity.name.tag.localname",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#67cbe7"
      }
    },
    {
      "name": "Tag punctuation",
      "scope": [
        "punctuation.definition.tag",
        "meta.tag punctuation"
      ],
      "settings": {
        "foreground": "#8a97a8"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#f2a7bb"
      }
    },
    {
      "name": "Selectors",
      "scope": [
        "meta.selector",
        "entity.other.attribute-name.class",
        "entity.other.attribute-name.id",
        "entity.other.attribute-name.pseudo-class",
        "entity.other.attribute-name.pseudo-element"
      ],
      "settings": {
        "foreground": "#67cbe7"
      }
    },
    {
      "name": "JSON / YAML keys",
      "scope": [
        "source.json meta.structure.dictionary > string.quoted.json",
        "source.json meta.structure.dictionary > string.quoted.json > punctuation.string",
        "support.type.property-name.json",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#dce6f2"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#b49cf0"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold",
        "punctuation.definition.bold"
      ],
      "settings": {
        "foreground": "#f2a7bb"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic",
        "punctuation.definition.italic"
      ],
      "settings": {
        "foreground": "#67cbe7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "markup.underline.link.image",
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#67cbe7"
      }
    },
    {
      "name": "Markdown quotes / list markers",
      "scope": [
        "markup.quote",
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#748396"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted",
        "markup.inserted.diff"
      ],
      "settings": {
        "foreground": "#9fd47e"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted",
        "markup.deleted.diff"
      ],
      "settings": {
        "foreground": "#ef7d86"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed",
        "markup.changed.diff"
      ],
      "settings": {
        "foreground": "#67cbe7"
      }
    }
  ],
